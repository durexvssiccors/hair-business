<!-- Custom Event Tracking -->
<script is:inline>
  // Track WhatsApp Clicks
  document.addEventListener('click', function(e) {
    const waLink = e.target.closest('a[href*="wa.me"]');
    if (waLink) {
      const location = window.location.pathname;
      const context = waLink.innerText || 'WhatsApp Button';
      
      // GA4
      if (typeof gtag === 'function') {
        gtag('event', 'whatsapp_click', {
          'page_location': location,
          'button_text': context
        });
      }
      
      // Meta Pixel
      if (typeof fbq === 'function') {
        fbq('trackCustom', 'WhatsAppContact', {
          'page': location,
          'label': context
        });
      }

      // TikTok
      if (typeof ttq === 'object') {
        ttq.track('Contact');
      }
    }
  });

  // Track Custom Builder Usage
  document.addEventListener('builder_add_item', function(e) {
    if (typeof gtag === 'function') {
      gtag('event', 'builder_item_added', {
        'item_type': e.detail.type,
        'item_texture': e.detail.texture,
        'item_length': e.detail.length
      });
    }
  });

  document.addEventListener('builder_whatsapp_quote', function(e) {
    if (typeof gtag === 'function') {
      gtag('event', 'builder_quote_request', {
        'total_value': e.detail.total,
        'item_count': e.detail.count
      });
    }
  });
</script>
