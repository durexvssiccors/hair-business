---
interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article' | 'product';
  slug?: string;
  frontmatter?: any;
  noindex?: boolean;
}

const {
  title = "Raw Vietnamese Hair in Ghana | Factory-Direct | Raw Hair Direct",
  description = "Buy 100% raw Vietnamese hair bundles, wigs & closures in Ghana. Factory-direct from Vietnam — no middlemen. Transparent pricing. WhatsApp orders in Accra.",
  image = "/assets/processed/raw-bone-straight-20in-bundles-128usd.jpg",
  type = "website",
  slug = "",
  frontmatter = {},
  noindex = false,
} = Astro.props;

const siteUrl = (Astro.site?.toString() || 'https://rawhairdirect.com').replace(/\/$/, '');
const resolvedSlug = slug || Astro.url?.pathname || '';
const canonicalURL = resolvedSlug
  ? new URL(resolvedSlug.startsWith('/') ? resolvedSlug : `/${resolvedSlug}`, siteUrl).href
  : siteUrl;
const socialImageURL = image.startsWith('http') ? image : `${siteUrl}${image}`;

const resolvedTitle = frontmatter?.title
  ? `${frontmatter.title} | Raw Hair Direct`
  : title;
const resolvedDescription = frontmatter?.description || description;

const keywordsArray: string[] = frontmatter?.keywords
  ? Array.isArray(frontmatter.keywords)
    ? frontmatter.keywords
    : frontmatter.keywords.split(',').map((k: string) => k.trim())
  : [
      "raw hair vendors Ghana",
      "raw hair vendors Accra",
      "raw Vietnamese hair Ghana",
      "raw Vietnamese hair bundles",
      "buy raw hair Ghana",
      "raw hair Accra",
      "factory direct hair Ghana",
      "raw virgin hair Ghana",
      "hair vendor Accra WhatsApp",
      "raw hair bundles Ghana",
      "Vietnamese hair vendor Ghana",
      "bone straight hair Ghana",
      "body wave hair Ghana",
      "raw hair wigs Ghana",
      "raw hair closures Ghana",
    ];

// ── WebSite schema (homepage only) ──────────────────────────────
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Raw Hair Direct",
  "url": siteUrl,
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": `${siteUrl}/products?q={search_term_string}`,
    },
    "query-input": "required name=search_term_string",
  },
};

// ── LocalBusiness / Organisation schema (site-wide) ─────────────
const orgSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": `${siteUrl}/#business`,
  "name": "Raw Hair Direct",
  "description": "Factory-direct raw Vietnamese hair vendor based in Ghana. Raw hair bundles, wigs, closures and frontals — no middlemen, transparent pricing.",
  "url": siteUrl,
  "telephone": "+233500601915",
  "email": "orders@rawhairdirect.com",
  "image": `${siteUrl}/assets/processed/raw-bone-straight-20in-bundles-128usd.jpg`,
  "logo": `${siteUrl}/favicon.svg`,
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Accra",
    "addressRegion": "Greater Accra",
    "addressCountry": "GH",
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "5.6037",
    "longitude": "-0.1870",
  },
  "areaServed": [
    { "@type": "Country", "name": "Ghana" },
    { "@type": "City", "name": "Accra" },
  ],
  "priceRange": "$$",
  "currenciesAccepted": "USD,GHS",
  "paymentAccepted": "Mobile Money, Bank Transfer",
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
    "opens": "08:00",
    "closes": "21:00",
  },
  "sameAs": [
    `https://wa.me/233500601915`,
    `https://www.instagram.com/rawhairdirect`,
  ],
  "hasMap": `https://www.google.com/maps/search/raw+hair+vendor+accra+ghana`,
};

// ── Per-page schema ──────────────────────────────────────────────
let pageSchema: Record<string, any>;

const isProduct = type === 'product' || resolvedSlug.startsWith('products/');
const isBlog    = type === 'article' || resolvedSlug.startsWith('content/blog/');
const isGuide   = resolvedSlug.startsWith('content/guides/');

if (isProduct) {
  pageSchema = {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": resolvedTitle.replace(" | Raw Hair Direct", ""),
    "description": resolvedDescription,
    "image": socialImageURL,
    "brand": { "@type": "Brand", "name": "Raw Hair Direct" },
    "manufacturer": {
      "@type": "Organization",
      "name": "Raw Hair Direct",
      "url": siteUrl,
    },
    "offers": {
      "@type": "Offer",
      "url": canonicalURL,
      "priceCurrency": "USD",
      "price": frontmatter?.price || "0",
      "priceValidUntil": new Date(new Date().setFullYear(new Date().getFullYear() + 1)).toISOString().split('T')[0],
      "availability": "https://schema.org/InStock",
      "itemCondition": "https://schema.org/NewCondition",
      "seller": {
        "@type": "Organization",
        "@id": `${siteUrl}/#business`,
        "name": "Raw Hair Direct",
      },
    },
    "isRelatedTo": [
      { "@type": "Product", "name": "Raw Bone Straight Hair Bundles", "url": `${siteUrl}/products/bundles/bone-straight-24-3bundle` },
      { "@type": "Product", "name": "Raw Body Wave Hair Bundles",     "url": `${siteUrl}/products/bundles/body-wave-20-22-24` },
    ],
  };
} else if (isBlog) {
  pageSchema = {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": resolvedTitle.replace(" | Raw Hair Direct", ""),
    "description": resolvedDescription,
    "image": socialImageURL,
    "url": canonicalURL,
    "datePublished": frontmatter?.date || new Date().toISOString(),
    "dateModified": frontmatter?.dateModified || frontmatter?.date || new Date().toISOString(),
    "author": {
      "@type": "Organization",
      "@id": `${siteUrl}/#business`,
      "name": "Raw Hair Direct",
    },
    "publisher": {
      "@type": "Organization",
      "@id": `${siteUrl}/#business`,
      "name": "Raw Hair Direct",
      "logo": { "@type": "ImageObject", "url": `${siteUrl}/favicon.svg` },
    },
    "mainEntityOfPage": { "@type": "WebPage", "@id": canonicalURL },
    "keywords": keywordsArray.join(", "),
    "inLanguage": "en-GH",
    "about": {
      "@type": "Thing",
      "name": "Raw Vietnamese Hair",
      "description": "Unprocessed, 100% raw Vietnamese human hair sold factory-direct in Ghana.",
    },
  };
} else if (isGuide) {
  pageSchema = {
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": resolvedTitle.replace(" | Raw Hair Direct", ""),
    "description": resolvedDescription,
    "image": socialImageURL,
    "author": {
      "@type": "Organization",
      "@id": `${siteUrl}/#business`,
      "name": "Raw Hair Direct",
    },
    "publisher": {
      "@type": "Organization",
      "@id": `${siteUrl}/#business`,
      "name": "Raw Hair Direct",
    },
    "url": canonicalURL,
    "inLanguage": "en-GH",
  };
} else {
  pageSchema = {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": resolvedTitle,
    "description": resolvedDescription,
    "url": canonicalURL,
    "inLanguage": "en-GH",
    "isPartOf": { "@type": "WebSite", "@id": `${siteUrl}/#website` },
  };
}

// ── BreadcrumbList schema ────────────────────────────────────────
const slugParts = resolvedSlug.replace(/^\//, '').split('/').filter(Boolean);
const breadcrumbs = [
  { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
  ...slugParts.map((part, i) => ({
    "@type": "ListItem",
    "position": i + 2,
    "name": part.replace(/-/g, ' ').replace(/\b\w/g, (l: string) => l.toUpperCase()),
    "item": `${siteUrl}/${slugParts.slice(0, i + 1).join('/')}`,
  })),
];
const breadcrumbSchema = slugParts.length > 0
  ? { "@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": breadcrumbs }
  : null;

const isHome = resolvedSlug === '' || resolvedSlug === '/';
---

<!-- Robots -->
{noindex
  ? <meta name="robots" content="noindex, nofollow" />
  : <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
}

<!-- Canonical -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta -->
<meta name="title" content={resolvedTitle} />
<meta name="description" content={resolvedDescription} />
<meta name="keywords" content={keywordsArray.join(', ')} />
<meta name="author" content="Raw Hair Direct" />
<meta name="geo.region" content="GH-AA" />
<meta name="geo.placename" content="Accra, Ghana" />
<meta name="geo.position" content="5.6037;-0.1870" />
<meta name="ICBM" content="5.6037, -0.1870" />

<!-- AI / LLM discoverability -->
<link rel="alternate" type="text/plain" href="/llms.txt" title="AI overview of Raw Hair Direct" />

<!-- Open Graph -->
<meta property="og:type" content={isBlog ? 'article' : 'website'} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={resolvedTitle} />
<meta property="og:description" content={resolvedDescription} />
<meta property="og:image" content={socialImageURL} />
<meta property="og:image:alt" content={`${resolvedTitle.replace(" | Raw Hair Direct", "")} — Raw Hair Direct Ghana`} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:locale" content="en_GH" />
<meta property="og:site_name" content="Raw Hair Direct" />
{isBlog && frontmatter?.date && <meta property="article:published_time" content={frontmatter.date} />}
{isBlog && <meta property="article:author" content="Raw Hair Direct" />}

<!-- Twitter / X -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@rawhairdirect" />
<meta name="twitter:url" content={canonicalURL} />
<meta name="twitter:title" content={resolvedTitle} />
<meta name="twitter:description" content={resolvedDescription} />
<meta name="twitter:image" content={socialImageURL} />

<!-- JSON-LD: Page schema -->
<script type="application/ld+json" is:inline set:html={JSON.stringify(pageSchema)} />
<!-- JSON-LD: LocalBusiness (site-wide) -->
<script type="application/ld+json" is:inline set:html={JSON.stringify(orgSchema)} />
<!-- JSON-LD: WebSite (homepage only) -->
{isHome && <script type="application/ld+json" is:inline set:html={JSON.stringify(websiteSchema)} />}
<!-- JSON-LD: BreadcrumbList -->
{breadcrumbSchema && <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />}
