---
import DocsLayout from '../layouts/DocsLayout.astro';

const publicPrefixes = [
    'products/',
    'content/guides/',
    'content/faq/',
    'content/blog/',
    'policies/',
];
const publicExactPaths = new Set([
    'content/about',
]);

function isPublicSlug(slug: string) {
    return publicPrefixes.some(prefix => slug.startsWith(prefix)) || publicExactPaths.has(slug);
}

export async function getStaticPaths() {
    const publicPrefixes = [
        'products/',
        'content/guides/',
        'content/faq/',
        'content/blog/',
        'policies/',
    ];
    const publicExactPaths = new Set([
        'content/about',
    ]);
    const isPublicSlug = (slug: string) =>
        publicPrefixes.some(prefix => slug.startsWith(prefix)) || publicExactPaths.has(slug);

    const nestedDocs = import.meta.glob('../../**/*.md');

    return Object.keys(nestedDocs)
        .map(path => {
            const slug = path.replace('../../', '').replace('.md', '');
            return { params: { slug } };
        })
        .filter(({ params }) => isPublicSlug(params.slug));
}

const docs = import.meta.glob('../../**/*.md', { eager: true });
const { slug } = Astro.params;
if (!isPublicSlug(slug)) {
    return Astro.redirect('/');
}
const path = `../../${slug}.md`;
const entry = docs[path] as any;

if (!entry) {
    return Astro.redirect('/404');
}

const { Content, frontmatter } = entry;

// Determine page type for SEO
function getPageType(slug: string): 'website' | 'article' | 'product' {
    if (slug.startsWith('products/')) return 'product';
    if (slug.startsWith('content/blog/')) return 'article';
    return 'website';
}
---

<DocsLayout
    title={frontmatter?.title}
    description={frontmatter?.description}
    image={frontmatter?.hero_image}
    type={getPageType(slug)}
    slug={slug}
    frontmatter={frontmatter}
>
    <Content />
</DocsLayout>
