---
import SEO from '../components/SEO.astro';
import Analytics from '../components/Analytics.astro';

const featured = [
  {
    slug: '/products/bundles/body-wave-20-22-24',
    name: 'MIYAKO No.1',
    type: 'Raw Body Wave · 13×4 Frontal',
    length: '24"',
    img: '/assets/processed/raw-body-wave-24in-13x4-highlight-wig-289usd-2.jpg',
    alt: 'Miyako No.1 — Raw Body Wave Highlight Frontal Wig 24 inch',
    kanji: '水',
    pos: 'card--feature',
  },
  {
    slug: '/products/wigs/deep-wave-wig-26',
    name: 'NOZOMI',
    type: 'Raw Bone Straight · 13×4 Frontal',
    length: '26"',
    img: '/assets/processed/raw-bone-straight-26in-13x4-wig-372usd.jpg',
    alt: 'Nozomi — Raw Bone Straight Frontal Wig 26 inch',
    kanji: '直',
    pos: 'card--tall',
  },
  {
    slug: '/products/closures/straight-closure-18',
    name: 'SAKURA',
    type: 'Raw Bone Straight · 5×5 Closure Wig',
    length: '22"',
    img: '/assets/processed/raw-bone-straight-22in-5x5-wig-side-259usd.jpg',
    alt: 'Sakura — Raw Bone Straight Closure Wig 22 inch',
    kanji: '花',
    pos: 'card--side',
  },
  {
    slug: '/products/bundles/bone-straight-24-3bundle',
    name: 'AKANE',
    type: 'Virgin Body Wave · Red-Black Frontal',
    length: '14"',
    img: '/assets/processed/virgin-body-wave-14in-red-black-wig-128usd.jpg',
    alt: 'Akane — Virgin Body Wave Red Black Frontal Wig',
    kanji: '茜',
    pos: 'card--accent',
  },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <SEO
    title="Raw Vietnamese Hair in Ghana | Factory-Direct | Raw Hair Direct"
    description="Buy 100% raw Vietnamese hair bundles, wigs & closures in Ghana. Factory-direct from Vietnam — no middlemen. Transparent pricing. WhatsApp orders in Accra."
    type="website"
    slug="/"
  />
  <title>Raw Vietnamese Hair in Ghana | Factory-Direct | Raw Hair Direct</title>
  <Analytics />

  <!-- Fonts: Big Shoulders Display (display), Cormorant Garamond (editorial serif), DM Sans (body) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@400;700;900&family=Cormorant+Garamond:ital,wght@1,400;1,600&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;1,9..40,300&display=swap" rel="stylesheet" />

  <style>
    /* ─── TOKENS ─────────────────────────────────────────────────────── */
    :root {
      --ink:       oklch(8% 0.012 45);
      --ink-soft:  oklch(14% 0.01 45);
      --white:     oklch(97% 0.008 85);
      --white-dim: oklch(90% 0.006 85);
      --red:       oklch(42% 0.19 22);
      --red-dim:   oklch(38% 0.16 22);
      --gold:      oklch(70% 0.10 78);
      --muted:     oklch(55% 0.008 80);

      --fd: 'Big Shoulders Display', 'Impact', sans-serif;
      --fs: 'Cormorant Garamond', Georgia, serif;
      --fb: 'DM Sans', system-ui, sans-serif;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; font-size: 16px; }
    body {
      font-family: var(--fb);
      background: var(--ink);
      color: var(--white);
      overflow-x: hidden;
    }
    a { color: inherit; text-decoration: none; cursor: pointer; }
    img { display: block; width: 100%; height: 100%; object-fit: cover; }

    /* ─── NAV ─────────────────────────────────────────────────────────── */
    .nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 300;
      display: flex; align-items: center; justify-content: space-between;
      padding: 1.5rem 3rem;
      transition: background 0.5s ease, border-color 0.5s ease;
      border-bottom: 1px solid transparent;
    }
    .nav.solid {
      background: var(--ink);
      border-color: oklch(20% 0.01 45);
    }
    .nav-logo {
      font-family: var(--fd);
      font-size: 1.1rem;
      font-weight: 900;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--white);
    }
    .nav-logo span {
      color: var(--red);
      margin-left: 0.05em;
    }
    .nav-center {
      font-family: var(--fb);
      font-size: 0.6rem;
      font-weight: 300;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: var(--muted);
    }
    .nav-links {
      display: flex; align-items: center; gap: 2.5rem; list-style: none;
    }
    .nav-links a {
      font-family: var(--fb);
      font-size: 0.62rem; font-weight: 300;
      letter-spacing: 0.26em; text-transform: uppercase;
      color: var(--white-dim);
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--white); }
    .nav-shop {
      font-family: var(--fd);
      font-size: 0.75rem; font-weight: 700;
      letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--ink) !important;
      background: var(--white);
      padding: 0.45rem 1.2rem;
      transition: background 0.2s, color 0.2s;
    }
    .nav-shop:hover {
      background: var(--red) !important;
      color: var(--white) !important;
    }
    .nav-ham {
      display: none; flex-direction: column; gap: 5px;
      cursor: pointer; padding: 4px; background: none; border: none;
    }
    .nav-ham span {
      display: block; width: 24px; height: 1px; background: var(--white);
      transition: transform 0.3s, opacity 0.3s;
    }

    /* ─── HERO ─────────────────────────────────────────────────────────── */
    .hero {
      position: relative;
      min-height: 100svh;
      display: grid;
      grid-template-columns: 54% 46%;
      overflow: hidden;
      background: var(--ink);
    }

    /* Kanji watermark */
    .hero-kanji {
      position: absolute;
      top: 50%; right: 3%;
      transform: translateY(-50%);
      font-size: clamp(18rem, 38vw, 56rem);
      line-height: 1;
      color: oklch(13% 0.01 45);
      font-weight: 900;
      pointer-events: none;
      z-index: 0;
      user-select: none;
      letter-spacing: -0.05em;
    }

    /* Red diagonal slash */
    .hero-slash {
      position: absolute;
      bottom: 0; left: 0;
      width: 100%; height: 100%;
      pointer-events: none;
      z-index: 1;
      overflow: hidden;
    }
    .hero-slash::after {
      content: '';
      position: absolute;
      top: -10%;
      left: 44%;
      width: 3px;
      height: 130%;
      background: var(--red);
      transform: rotate(8deg);
      transform-origin: top;
      opacity: 0.5;
    }

    /* Left: text block */
    .hero-left {
      position: relative;
      z-index: 2;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding: 0 3rem 5rem 3rem;
      padding-top: 8rem;
    }

    .hero-eyebrow {
      display: flex; align-items: center; gap: 1rem;
      font-family: var(--fb);
      font-size: 0.58rem; font-weight: 300;
      letter-spacing: 0.4em; text-transform: uppercase;
      color: var(--red);
      margin-bottom: 1.5rem;
    }
    .hero-eyebrow::before {
      content: '';
      display: inline-block;
      width: 2rem; height: 1px;
      background: var(--red);
    }

    .hero-h1 {
      font-family: var(--fd);
      font-weight: 900;
      line-height: 0.88;
      letter-spacing: -0.02em;
      text-transform: uppercase;
      color: var(--white);
      margin-bottom: 0;
    }
    .hero-h1 .line-sm {
      font-size: clamp(2.5rem, 5.5vw, 6rem);
      font-style: normal;
      color: var(--muted);
      letter-spacing: 0.08em;
      font-weight: 400;
    }
    .hero-h1 .line-xl {
      font-size: clamp(6rem, 15vw, 18rem);
      display: block;
    }
    .hero-h1 .line-serif {
      font-family: var(--fs);
      font-style: italic;
      font-weight: 400;
      font-size: clamp(4.5rem, 10vw, 13rem);
      color: var(--white-dim);
      display: block;
      letter-spacing: -0.01em;
    }

    .hero-stamp {
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      margin: 2.5rem 0 3rem;
    }
    .hero-stamp-box {
      border: 2px solid var(--red);
      padding: 0.3rem 0.65rem;
      font-family: var(--fd);
      font-size: 1.5rem;
      font-weight: 900;
      letter-spacing: 0.05em;
      color: var(--red);
      line-height: 1;
      text-transform: uppercase;
    }
    .hero-stamp-text {
      font-family: var(--fb);
      font-size: 0.6rem; font-weight: 300;
      letter-spacing: 0.3em; text-transform: uppercase;
      color: var(--white-dim);
      line-height: 1.8;
    }

    .hero-cta {
      display: inline-flex; align-items: center; gap: 1.5rem;
      font-family: var(--fd);
      font-size: 1rem; font-weight: 700;
      letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--white);
      transition: letter-spacing 0.3s, gap 0.3s;
    }
    .hero-cta:hover { letter-spacing: 0.28em; gap: 2rem; }
    .hero-cta-line {
      width: 3rem; height: 1px;
      background: linear-gradient(to right, var(--red), var(--white));
      flex-shrink: 0;
      transition: width 0.3s;
    }
    .hero-cta:hover .hero-cta-line { width: 4.5rem; }

    /* Right: Sculpture */
    .hero-right {
      position: relative;
      z-index: 2;
      overflow: hidden;
    }

    .sculpture-stage {
      width: 100%; height: 100%;
      perspective: 1600px;
      perspective-origin: 40% 50%;
    }

    .sculpture-scene {
      width: 100%; height: 100%;
      position: relative;
      transform-style: preserve-3d;
      transform: rotateY(-10deg) rotateX(2deg);
      will-change: transform;
      transition: transform 0.08s linear;
    }

    /* Deep shadow echo */
    .sculpture-echo {
      position: absolute;
      inset: 0;
      transform: translateZ(-80px) translate(28px, 22px);
      filter: blur(22px) brightness(0.2) saturate(0.4);
      opacity: 0.7;
    }
    .sculpture-echo img {
      height: 100%;
      object-position: center top;
    }

    /* Main image */
    .sculpture-main {
      position: absolute;
      inset: 0;
      transform: translateZ(0);
    }
    .sculpture-main img {
      height: 100%;
      object-position: center top;
    }

    /* Shimmer overlay */
    .sculpture-shimmer {
      position: absolute;
      inset: 0;
      transform: translateZ(10px);
      background: linear-gradient(
        128deg,
        transparent 0%,
        transparent 38%,
        oklch(97% 0.008 85 / 0.06) 48%,
        transparent 58%,
        transparent 100%
      );
      pointer-events: none;
    }

    /* Top fade so hero bleeds into next section */
    .hero-right::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to left,
        transparent 70%,
        var(--ink) 100%
      );
      z-index: 3;
      pointer-events: none;
    }

    /* Hero bottom fade */
    .hero::after {
      content: '';
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 30%;
      background: linear-gradient(to top, var(--ink), transparent);
      z-index: 1;
      pointer-events: none;
    }

    /* ─── TICKER ──────────────────────────────────────────────────────── */
    .ticker {
      background: var(--red);
      overflow: hidden;
      padding: 0.85rem 0;
      position: relative;
      z-index: 10;
    }
    .ticker-track {
      display: flex;
      width: max-content;
      animation: ticker-scroll 28s linear infinite;
    }
    .ticker-track:hover { animation-play-state: paused; }
    .ticker-item {
      display: flex; align-items: center; gap: 2.5rem;
      flex-shrink: 0;
      padding-right: 2.5rem;
    }
    .ticker-text {
      font-family: var(--fd);
      font-size: 0.9rem; font-weight: 700;
      letter-spacing: 0.22em; text-transform: uppercase;
      color: var(--white);
      white-space: nowrap;
    }
    .ticker-sep {
      color: oklch(90% 0.15 22);
      font-size: 0.6rem;
      flex-shrink: 0;
    }
    @keyframes ticker-scroll {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }

    /* ─── SECTION LABEL SYSTEM ────────────────────────────────────────── */
    .section-label {
      font-family: var(--fb);
      font-size: 0.58rem; font-weight: 300;
      letter-spacing: 0.5em; text-transform: uppercase;
      color: var(--muted);
    }

    /* ─── COLLECTION ──────────────────────────────────────────────────── */
    .collection {
      background: var(--white);
      color: var(--ink);
      padding: 6rem 0 0;
    }
    .collection-header {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      padding: 0 3rem 3.5rem;
    }
    .collection-title {
      font-family: var(--fd);
      font-size: clamp(3.5rem, 7vw, 8rem);
      font-weight: 900;
      letter-spacing: -0.02em;
      line-height: 0.9;
      text-transform: uppercase;
      color: var(--ink);
    }
    .collection-title em {
      font-family: var(--fs);
      font-style: italic;
      font-weight: 600;
      color: var(--red);
    }
    .collection-desc {
      max-width: 22ch;
      font-family: var(--fb);
      font-size: 0.82rem; font-weight: 300;
      line-height: 1.7;
      color: oklch(40% 0.008 45);
      text-align: right;
    }

    .collection-grid {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr;
      grid-template-rows: 68vh 52vh;
      gap: 3px;
      background: oklch(85% 0.005 80);
    }

    .card {
      position: relative;
      overflow: hidden;
      background: oklch(92% 0.005 80);
      cursor: pointer;
    }
    .card img {
      height: 100%;
      object-position: center top;
      transition: transform 1.1s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .card:hover img { transform: scale(1.05); }

    /* Grid positions */
    .card--feature { grid-column: 1; grid-row: 1; }
    .card--tall    { grid-column: 2 / 4; grid-row: 1; }
    .card--side    { grid-column: 1 / 3; grid-row: 2; }
    .card--accent  { grid-column: 3; grid-row: 2; }

    /* Card info overlay */
    .card-overlay {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      padding: 2rem;
      background: linear-gradient(to top, oklch(8% 0.012 45 / 0.85) 0%, transparent 100%);
      color: var(--white);
      transform: translateY(0.5rem);
      opacity: 0;
      transition: opacity 0.4s ease, transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .card:hover .card-overlay {
      opacity: 1;
      transform: translateY(0);
    }
    .card-name {
      font-family: var(--fd);
      font-size: clamp(1.5rem, 2.5vw, 2.5rem);
      font-weight: 900;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      line-height: 1;
    }
    .card-type {
      font-family: var(--fb);
      font-size: 0.62rem; font-weight: 300;
      letter-spacing: 0.28em; text-transform: uppercase;
      color: var(--white-dim);
      margin-top: 0.35rem;
    }
    .card-length {
      position: absolute;
      top: 1.5rem; right: 1.75rem;
      font-family: var(--fd);
      font-size: 0.75rem; font-weight: 700;
      letter-spacing: 0.18em;
      color: var(--white);
      background: var(--red);
      padding: 0.2rem 0.5rem;
      opacity: 0;
      transition: opacity 0.3s ease 0.1s;
    }
    .card:hover .card-length { opacity: 1; }

    /* Kanji watermark on card */
    .card-kanji {
      position: absolute;
      top: 0.75rem; left: 1.25rem;
      font-size: 1.6rem;
      color: var(--white);
      opacity: 0.25;
      line-height: 1;
      pointer-events: none;
      z-index: 2;
      user-select: none;
    }

    /* Card CTA arrow */
    .card-arrow {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      margin-top: 0.85rem;
      font-family: var(--fd);
      font-size: 0.7rem; font-weight: 700;
      letter-spacing: 0.25em; text-transform: uppercase;
      color: var(--white);
    }
    .card-arrow::after {
      content: '→';
      font-family: var(--fb);
      font-style: normal;
      font-size: 0.9rem;
    }

    /* Collection footer link */
    .collection-footer {
      padding: 3.5rem 3rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .collection-count {
      font-family: var(--fd);
      font-size: 4rem; font-weight: 900;
      letter-spacing: -0.02em;
      color: oklch(88% 0.005 80);
      line-height: 1;
    }
    .collection-all {
      display: inline-flex;
      align-items: center;
      gap: 1.25rem;
      font-family: var(--fd);
      font-size: 1rem; font-weight: 700;
      letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--ink);
      border-bottom: 2px solid var(--red);
      padding-bottom: 0.15rem;
      transition: color 0.2s, gap 0.3s;
    }
    .collection-all:hover { color: var(--red); gap: 1.75rem; }

    /* ─── STATEMENT ───────────────────────────────────────────────────── */
    .statement {
      background: var(--ink);
      padding: 8rem 3rem;
      display: grid;
      grid-template-columns: 1fr 2fr;
      gap: 4rem;
      align-items: center;
      position: relative;
      overflow: hidden;
    }
    .statement-kanji {
      position: absolute;
      right: -2%;
      top: 50%;
      transform: translateY(-50%);
      font-size: clamp(12rem, 28vw, 36rem);
      line-height: 1;
      color: oklch(12% 0.01 45);
      pointer-events: none;
      user-select: none;
      z-index: 0;
    }
    .statement-left {
      position: relative; z-index: 1;
    }
    .statement-num {
      font-family: var(--fd);
      font-size: clamp(5rem, 12vw, 15rem);
      font-weight: 900;
      letter-spacing: -0.04em;
      line-height: 1;
      color: var(--red);
      display: block;
    }
    .statement-num-label {
      font-family: var(--fb);
      font-size: 0.6rem; font-weight: 300;
      letter-spacing: 0.4em; text-transform: uppercase;
      color: var(--muted);
      display: block;
      margin-top: 0.5rem;
    }
    .statement-right {
      position: relative; z-index: 1;
    }
    .statement-heading {
      font-family: var(--fd);
      font-size: clamp(2.5rem, 5.5vw, 7rem);
      font-weight: 900;
      line-height: 0.92;
      letter-spacing: -0.02em;
      text-transform: uppercase;
      color: var(--white);
      margin-bottom: 2rem;
    }
    .statement-heading em {
      font-family: var(--fs);
      font-style: italic;
      font-weight: 400;
      color: var(--white-dim);
      display: block;
    }
    .statement-body {
      font-family: var(--fb);
      font-size: 0.9rem; font-weight: 300;
      line-height: 1.85;
      color: var(--white-dim);
      max-width: 46ch;
      margin-bottom: 2.5rem;
    }
    .statement-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
    .statement-list li {
      font-family: var(--fb);
      font-size: 0.7rem; font-weight: 300;
      letter-spacing: 0.3em; text-transform: uppercase;
      color: var(--muted);
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }
    .statement-list li::before {
      content: '';
      display: inline-block;
      width: 1.5rem; height: 1px;
      background: var(--red);
    }

    /* ─── STRIP IMAGE ─────────────────────────────────────────────────── */
    .strip {
      height: 55vh;
      position: relative;
      overflow: hidden;
    }
    .strip img {
      height: 100%;
      object-position: center 25%;
      filter: grayscale(20%) contrast(1.05);
    }
    .strip-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to right,
        var(--ink) 0%,
        transparent 40%,
        transparent 60%,
        var(--ink) 100%
      );
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .strip-text {
      font-family: var(--fd);
      font-size: clamp(2.5rem, 6vw, 8rem);
      font-weight: 900;
      letter-spacing: -0.01em;
      text-transform: uppercase;
      color: var(--white);
      text-align: center;
      line-height: 0.9;
    }
    .strip-text em {
      font-family: var(--fs);
      font-style: italic;
      font-weight: 400;
      color: var(--red);
      display: block;
      font-size: 0.7em;
    }

    /* ─── FINAL CTA ───────────────────────────────────────────────────── */
    .cta {
      background: var(--white);
      color: var(--ink);
      padding: 8rem 3rem;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .cta::before {
      content: '髪';
      position: absolute;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      font-size: clamp(18rem, 42vw, 56rem);
      line-height: 1;
      color: oklch(92% 0.005 80);
      pointer-events: none;
      user-select: none;
      z-index: 0;
    }
    .cta-inner { position: relative; z-index: 1; }
    .cta-eyebrow {
      font-family: var(--fb);
      font-size: 0.6rem; font-weight: 300;
      letter-spacing: 0.5em; text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 2rem;
    }
    .cta-heading {
      font-family: var(--fd);
      font-size: clamp(4rem, 11vw, 14rem);
      font-weight: 900;
      letter-spacing: -0.03em;
      line-height: 0.88;
      text-transform: uppercase;
      color: var(--ink);
      margin-bottom: 3.5rem;
    }
