---
import SEO from '../components/SEO.astro';
import Analytics from '../components/Analytics.astro';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <SEO
    title="Raw Hair Direct"
    description="Luxury Raw Vietnamese Hair. Factory-direct to Ghana. No middlemen."
  />
  <Analytics />
  <title>Raw Hair Direct</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet" />
  <style>
    :root {
      --dark:   #08060400;
      --ink:    #080604;
      --cream:  #F5F0E8;
      --gold:   #C49A3C;
      --muted:  rgba(245,240,232,0.42);
      --fh:     'Playfair Display', Georgia, serif;
      --fb:     'Inter', system-ui, sans-serif;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: var(--fb);
      background: var(--ink);
      color: var(--cream);
      overflow-x: hidden;
    }
    a { color: inherit; text-decoration: none; cursor: pointer; }
    img { display: block; width: 100%; height: 100%; object-fit: cover; }

    /* ─── NAV ─── */
    .nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 200;
      display: flex; align-items: center; justify-content: space-between;
      padding: 1.75rem 2.5rem;
      transition: background 0.4s ease;
    }
    .nav.solid { background: var(--ink); }
    .nav-logo {
      font-family: var(--fh);
      font-size: 0.85rem; font-weight: 700;
      letter-spacing: 0.12em; text-transform: uppercase;
      color: var(--cream);
    }
    .nav-links {
      display: flex; align-items: center;
      gap: 2.5rem; list-style: none;
    }
    .nav-links a {
      font-size: 0.6rem; font-weight: 400;
      letter-spacing: 0.28em; text-transform: uppercase;
      color: var(--muted);
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--cream); }
    .nav-build {
      font-size: 0.6rem; font-weight: 600;
      letter-spacing: 0.22em; text-transform: uppercase;
      color: var(--gold);
      border: 1px solid rgba(196,154,60,0.5);
      padding: 0.55rem 1.25rem;
      transition: all 0.25s;
    }
    .nav-build:hover {
      background: var(--gold); color: var(--ink);
      border-color: var(--gold);
    }
    .nav-ham {
      display: none; flex-direction: column; gap: 5px;
      cursor: pointer; padding: 4px;
    }
    .nav-ham span {
      display: block; width: 22px; height: 1px; background: var(--cream);
    }

    /* ─── HERO ─── */
    .hero {
      min-height: 100vh;
      display: grid;
      grid-template-columns: 55fr 45fr;
      background: var(--ink);
      overflow: hidden;
    }
    .hero-left {
      display: flex; flex-direction: column;
      justify-content: flex-end;
      padding: 0 4rem 5rem 4rem;
      position: relative; z-index: 1;
    }
    .hero-eyebrow {
      font-size: 0.55rem; font-weight: 400;
      letter-spacing: 0.35em; text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 1.5rem;
    }
    .hero-h1 {
      font-family: var(--fh);
      font-size: clamp(5rem, 13vw, 17rem);
      font-weight: 700;
      line-height: 0.87;
      letter-spacing: -0.03em;
      color: var(--cream);
    }
    .hero-h1 em {
      display: block;
      font-style: italic;
      font-weight: 400;
    }
    .hero-rule {
      width: 2.5rem; height: 1px;
      background: var(--gold);
      margin: 2.5rem 0;
    }
    .hero-meta {
      display: flex; flex-direction: column; gap: 0.45rem;
      margin-bottom: 3.5rem;
    }
    .hero-meta span {
      font-size: 0.55rem; font-weight: 400;
      letter-spacing: 0.3em; text-transform: uppercase;
      color: var(--muted);
    }
    .hero-cta {
      display: inline-flex; align-items: center; gap: 1.25rem;
      font-size: 0.6rem; font-weight: 600;
      letter-spacing: 0.25em; text-transform: uppercase;
      color: var(--cream);
      transition: gap 0.35s ease, letter-spacing 0.35s ease;
    }
    .hero-cta:hover { gap: 1.75rem; letter-spacing: 0.3em; }
    .hero-cta-arrow {
      width: 32px; height: 1px; background: var(--gold);
      position: relative; flex-shrink: 0;
    }
    .hero-cta-arrow::after {
      content: '';
      position: absolute; right: 0; top: -3px;
      width: 6px; height: 6px;
      border-right: 1px solid var(--gold);
      border-top: 1px solid var(--gold);
      transform: rotate(45deg);
    }

    .hero-right {
      position: relative; overflow: hidden;
      background: #13100c;
    }
    .hero-right img {
      position: absolute; inset: 0;
      object-position: center top;
    }
    .hero-right::after {
      content: '';
      position: absolute; inset: 0;
      background: linear-gradient(to right, rgba(8,6,4,0.25) 0%, transparent 35%);
    }

    /* ─── STATEMENT ─── */
    .statement {
      background: var(--cream);
      min-height: 70vh;
      display: flex; align-items: center; justify-content: center;
      padding: 10rem 4rem;
    }
    .statement-quote {
      font-family: var(--fh);
      font-size: clamp(2.75rem, 5.5vw, 7.5rem);
      font-style: italic;
      font-weight: 400;
      line-height: 1.12;
      letter-spacing: -0.01em;
      color: var(--ink);
      text-align: center;
      max-width: 18ch;
    }

    /* ─── EDITORIAL ─── */
    .editorial {
      background: var(--ink);
    }
    .editorial-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
    }
    .ed-item {
      position: relative; overflow: hidden;
    }
    .ed-item img {
      display: block;
      width: 100%; height: 75vh;
      object-fit: cover; object-position: center top;
      transition: transform 0.9s cubic-bezier(0.16,1,0.3,1);
    }
    .ed-item:hover img { transform: scale(1.04); }
    .ed-item + .ed-item {
      border-left: 1px solid rgba(245,240,232,0.06);
    }
    .ed-info {
      position: absolute; bottom: 0; left: 0; right: 0;
      padding: 2.5rem 2rem;
      background: linear-gradient(to top, rgba(8,6,4,0.75) 0%, transparent 100%);
    }
    .ed-label {
      display: block;
      font-size: 0.58rem; font-weight: 700;
      letter-spacing: 0.28em; text-transform: uppercase;
      color: var(--cream); margin-bottom: 0.35rem;
    }
    .ed-sub {
      display: block;
      font-size: 0.52rem; font-weight: 300;
      letter-spacing: 0.22em; text-transform: uppercase;
      color: var(--muted);
    }

    /* ─── MANIFESTO ─── */
    .manifesto {
      background: var(--cream);
      padding: 12rem 4rem;
      display: flex; flex-direction: column;
      align-items: center; text-align: center;
    }
    .sec-label {
      font-size: 0.55rem; font-weight: 600;
      letter-spacing: 0.32em; text-transform: uppercase;
      color: var(--gold); margin-bottom: 2.5rem;
    }
    .manifesto-h2 {
      font-family: var(--fh);
      font-size: clamp(2.5rem, 6.5vw, 9rem);
      font-weight: 600;
      line-height: 1.0;
      letter-spacing: -0.025em;
      color: var(--ink);
      margin-bottom: 2.5rem;
    }
    .manifesto-meta {
      font-size: 0.6rem; font-weight: 300;
      letter-spacing: 0.25em; text-transform: uppercase;
      color: rgba(8,6,4,0.38);
      line-height: 2.2; margin-bottom: 3.5rem;
    }
    .manifesto-link {
      display: inline-flex; align-items: center; gap: 1rem;
      font-size: 0.58rem; font-weight: 600;
      letter-spacing: 0.28em; text-transform: uppercase;
      color: var(--ink);
      border-bottom: 1px solid var(--gold);
      padding-bottom: 0.2rem;
      transition: color 0.2s, gap 0.3s;
    }
    .manifesto-link:hover { color: var(--gold); gap: 1.5rem; }

    /* ─── BUILDER ─── */
    .build {
      background: var(--ink);
      padding: 12rem 4rem;
      display: flex; flex-direction: column;
      align-items: center; text-align: center;
    }
    .build-h2 {
      font-family: var(--fh);
      font-size: clamp(3rem, 8vw, 12rem);
      font-weight: 700;
      line-height: 0.93;
      letter-spacing: -0.03em;
      color: var(--cream);
      margin-bottom: 3.5rem;
    }
    .build-rule {
      width: 3rem; height: 1px;
      background: var(--gold);
      margin-bottom: 3.5rem;
    }
    .build-cta {
      display: inline-flex; align-items: center; gap: 1.5rem;
      font-size: 0.6rem; font-weight: 600;
      letter-spacing: 0.3em; text-transform: uppercase;
      color: var(--cream);
      border: 1px solid rgba(245,240,232,0.25);
      padding: 1.25rem 3rem;
      transition: all 0.25s;
    }
    .build-cta:hover {
      background: var(--gold);
      border-color: var(--gold);
      color: var(--ink);
      gap: 2rem;
    }

    /* ─── FOOTER ─── */
    .footer {
      background: var(--ink);
      border-top: 1px solid rgba(245,240,232,0.07);
      padding: 3.5rem 4rem;
    }
    .footer-inner {
      max-width: 1300px; margin: 0 auto;
      display: flex; align-items: center; justify-content: space-between;
      gap: 2rem;
    }
    .footer-brand {
      font-family: var(--fh);
      font-size: 0.9rem; font-weight: 600;
      letter-spacing: 0.08em; text-transform: uppercase;
      color: var(--cream);
    }
    .footer-links {
      display: flex; flex-wrap: wrap; gap: 1.75rem; list-style: none;
    }
    .footer-links a {
      font-size: 0.58rem; font-weight: 300;
      letter-spacing: 0.2em; text-transform: uppercase;
      color: rgba(245,240,232,0.3);
      transition: color 0.2s;
    }
    .footer-links a:hover { color: var(--cream); }
    .footer-copy {
      font-size: 0.55rem; letter-spacing: 0.12em; text-transform: uppercase;
      color: rgba(245,240,232,0.18);
      white-space: nowrap;
    }

    /* ─── REVEAL ─── */
    .r {
      opacity: 0; transform: translateY(18px);
      transition: opacity 1s cubic-bezier(0.16,1,0.3,1),
                  transform 1s cubic-bezier(0.16,1,0.3,1);
    }
    .r.in { opacity: 1; transform: none; }
    .r.d1 { transition-delay: 0.12s; }
    .r.d2 { transition-delay: 0.24s; }
    .r.d3 { transition-delay: 0.36s; }

    /* ─── RESPONSIVE ─── */
    @media (max-width: 860px) {
      .hero { grid-template-columns: 1fr; min-height: auto; }
      .hero-right { height: 60vw; min-height: 300px; }
      .hero-right img { position: relative; width: 100%; height: 100%; }
      .hero-right::after { background: linear-gradient(to top, rgba(8,6,4,0.3) 0%, transparent 60%); }
      .hero-left { padding: 3.5rem 2rem 4rem; }
      .hero-h1 { font-size: clamp(4rem, 18vw, 8rem); }

      .editorial-grid { grid-template-columns: 1fr; }
      .ed-item + .ed-item { border-left: none; border-top: 1px solid rgba(245,240,232,0.06); }
      .ed-item img { height: 70vw; }

      .manifesto { padding: 7rem 2rem; }
      .build { padding: 7rem 2rem; }
      .statement { padding: 7rem 2rem; }

      .footer-inner { flex-direction: column; text-align: center; gap: 1.5rem; }
      .footer-links { justify-content: center; }
    }
    /* MOBILE MENU */
    .mobile-menu {
      display: none;
      position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 190;
      background: var(--ink);
      flex-direction: column; align-items: center; justify-content: center;
      gap: 2.5rem;
    }
    .mobile-menu.open { display: flex; }
    .mobile-menu a { font-size: 1.4rem; font-family: var(--fh); font-weight: 700; }
    .mobile-menu-close { position: absolute; top: 1.5rem; right: 1.75rem; cursor: pointer; font-size: 1.5rem; color: var(--muted); background: none; border: none; color: var(--muted); }

    @media (max-width: 540px) {
      .nav { padding: 1.25rem 1.5rem; }
      .nav-links { display: none; }
      .nav-ham { display: flex; }
      .nav-build { display: none; }

      .hero-left { padding: 2.5rem 1.5rem 3.5rem; }
      .hero-h1 { font-size: 19vw; }

      .build-h2 { font-size: clamp(2.5rem, 13vw, 6rem); }
    }
  </style>
</head>
<body>

  <!-- NAV -->
  <nav class="nav" id="nav">
    <a href="/" class="nav-logo">Raw Hair Direct</a>
    <ul class="nav-links">
      <li><a href="/products">Collection</a></li>
      <li><a href="/content/about">Our Story</a></li>
      <li><a href="/content/guides/how-many-bundles-do-i-need">Guides</a></li>
      <li><a href="/custom-builder" class="nav-build">Build Set</a></li>
    </ul>
    <div class="nav-ham" id="ham" role="button" tabindex="0" aria-label="Menu">
      <span></span><span></span><span></span>
    </div>
  </nav>

  <!-- MOBILE MENU -->
  <div class="mobile-menu" id="mobile-menu">
    <button class="mobile-menu-close" id="mobile-close" aria-label="Close menu">✕</button>
    <a href="/products">Collection</a>
    <a href="/content/about">Our Story</a>
    <a href="/content/guides/how-many-bundles-do-i-need">Guides</a>
    <a href="/custom-builder" style="color: var(--gold);">Build Your Set</a>
  </div>

  <!-- ① HERO -->
  <section class="hero">
    <div class="hero-left">
      <p class="hero-eyebrow r">Raw Vietnamese · Ghana Direct</p>
      <h1 class="hero-h1 r d1">
        LUXURY
        <em>HAIR.</em>
      </h1>
      <div class="hero-rule r d2"></div>
      <div class="hero-meta r d2">
        <span>Direct from source</span>
        <span>Vietnam — Ghana</span>
      </div>
      <a href="/custom-builder" class="hero-cta r d3">
        Discover the Collection
        <span class="hero-cta-arrow"></span>
      </a>
    </div>
    <div class="hero-right">
      <img
        src="/assets/processed/raw-bone-straight-28in-13x4-wig-405usd.jpg"
        alt="28 inch Bone Straight Frontal Wig"
        loading="eager"
        fetchpriority="high"
      />
    </div>
  </section>

  <!-- ② STATEMENT -->
  <section class="statement">
    <p class="statement-quote r">
      Soft movement.<br />
      Real fullness.<br />
      Clean finish.
    </p>
  </section>

  <!-- ③ EDITORIAL GRID -->
  <section class="editorial">
    <div class="editorial-grid">
      <div class="ed-item r">
        <img
          src="/assets/processed/raw-bone-straight-22in-5x5-wig-side-259usd.jpg"
          alt="Bone Straight 5x5 Wig 22 inch"
          loading="lazy"
        />
        <div class="ed-info">
          <span class="ed-label">Bone Straight</span>
          <span class="ed-sub">Raw Vietnamese · 22"</span>
        </div>
      </div>
      <div class="ed-item r d1">
        <img
          src="/assets/processed/raw-body-wave-24in-13x4-highlight-wig-289usd-2.jpg"
          alt="Body Wave Highlight 13x4 Wig 24 inch"
          loading="lazy"
        />
        <div class="ed-info">
          <span class="ed-label">Body Wave Highlight</span>
          <span class="ed-sub">Raw Vietnamese · 24"</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ④ MANIFESTO -->
  <section class="manifesto">
    <p class="sec-label r">The Difference</p>
    <h2 class="manifesto-h2 r d1">
      Built for women<br />
      who know.
    </h2>
    <p class="manifesto-meta r d2">
      Factory-direct from Vietnam<br />
      No middlemen · Ghana-local support
    </p>
    <a href="/content/about" class="manifesto-link r d3">
      Our Story
      <span style="font-family: var(--fh); font-style: italic;">→</span>
    </a>
  </section>

  <!-- ⑤ BUILD CTA -->
  <section class="build">
    <p class="sec-label r">Custom Package Builder</p>
    <h2 class="build-h2 r d1">
      YOUR LENGTHS.<br />
      <em style="font-family: var(--fh); font-style: italic; font-weight:400;">Your textures.</em><br />
      YOUR PRICE.
    </h2>
    <div class="build-rule r d2"></div>
    <a href="/custom-builder" class="build-cta r d3">
      Build Your Set
      <span style="font-family: var(--fh); font-style: italic;">→</span>
    </a>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <p class="footer-brand">Raw Hair Direct</p>
      <ul class="footer-links">
        <li><a href="/products">Collection</a></li>
        <li><a href="/content/about">About</a></li>
        <li><a href="/content/guides">Guides</a></li>
        <li><a href="/custom-builder">Build a Set</a></li>
        <li><a href="/policies/shipping">Shipping</a></li>
        <li><a href="/policies/returns">Returns</a></li>
        <li><a href="https://wa.me/233500601915" target="_blank" rel="noopener">WhatsApp</a></li>
      </ul>
      <p class="footer-copy">© {new Date().getFullYear()} Raw Hair Direct</p>
    </div>
  </footer>

  <script>
    // Nav solid on scroll
    const nav = document.getElementById('nav');
    window.addEventListener('scroll', () => {
      nav?.classList.toggle('solid', window.scrollY > 80);
    }, { passive: true });

    // Mobile menu
    const ham = document.getElementById('ham');
    const mobileMenu = document.getElementById('mobile-menu');
    const mobileClose = document.getElementById('mobile-close');
    ham?.addEventListener('click', () => mobileMenu?.classList.add('open'));
    mobileClose?.addEventListener('click', () => mobileMenu?.classList.remove('open'));
    ham?.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') mobileMenu?.classList.toggle('open'); });
    mobileMenu?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => mobileMenu.classList.remove('open')));

    // Scroll reveal
    const items = document.querySelectorAll('.r');
    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver(
        entries => entries.forEach(e => {
          if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
        }),
        { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
      );
      items.forEach(el => io.observe(el));
    } else {
      items.forEach(el => el.classList.add('in'));
    }
    // Hero fires immediately
    document.querySelectorAll('.hero .r').forEach(el => el.classList.add('in'));

    // Reduce motion
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      items.forEach(el => el.classList.add('in'));
    }
  </script>

</body>
</html>
